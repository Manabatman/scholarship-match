# Database - use PostgreSQL for production
# SQLite (development): sqlite:///./dev.db
# PostgreSQL: postgresql://user:password@host:5432/dbname
# Note: For PostgreSQL, install psycopg2-binary
DATABASE_URL=sqlite:///./dev.db

# CORS - comma-separated allowed origins
# Add your production domain, e.g. https://iskonnect.ph
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT secret - generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Optional: JWT algorithm and token expiry
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# Set AUTH_DISABLED=false in production to require JWT on protected endpoints
# AUTH_DISABLED=true allows unauthenticated access (development)
AUTH_DISABLED=true

# Sentry - set SENTRY_DSN to enable error tracking (get from sentry.io)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
